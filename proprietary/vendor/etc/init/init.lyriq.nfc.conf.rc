on property:ro.vendor.hw.radio=JAPAN
   setprop persist.vendor.nfc.config_file_name libnfc-nxp-SN220P.conf

on property:ro.vendor.hw.radio=ROW && property:vendor.qti.nfc.chipid=0xca
   setprop persist.vendor.nfc.config_file_name libnfc-nxp-PN560.conf

on property:ro.vendor.hw.radio=ROW && property:vendor.qti.nfc.chipid=0xc1
   setprop persist.vendor.nfc.config_file_name libnfc-nxp-SN220E.conf